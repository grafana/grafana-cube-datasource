      "panel-8": {
        "kind": "Panel",
        "spec": {
          "id": 8,
          "title": "Advanced (JSON viewer demo): OR Filter \u2014 Credit Card or Active Customer",
          "description": "This panel uses an OR filter group across different field keys (payment_method OR is_active), which the visual editor cannot represent. OR is needed when combining conditions across different fields \u2014 equals with an array only works for multiple values on a single field.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-cube-datasource",
                      "version": "v0",
                      "datasource": {
                        "name": "grafana-cube-datasource"
                      },
                      "spec": {
                        "dimensions": [
                          "order_details.customers_first_name"
                        ],
                        "filters": [
                          {
                            "or": [
                              {
                                "member": "order_details.payments_payment_method",
                                "operator": "equals",
                                "values": [
                                  "credit_card"
                                ]
                              },
                              {
                                "member": "order_details.customers_is_active",
                                "operator": "equals",
                                "values": [
                                  "true"
                                ]
                              }
                            ]
                          }
                        ],
                        "measures": [
                          "order_details.payments_total_amount"
                        ]
                      }
                    },
                    "refId": "Credit Card or Active Customer",
                    "hidden": true
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-cube-datasource",
                      "version": "v0",
                      "datasource": {
                        "name": "grafana-cube-datasource"
                      },
                      "spec": {
                        "dimensions": [
                          "order_details.customers_first_name"
                        ],
                        "filters": [
                          {
                            "member": "order_details.payments_payment_method",
                            "operator": "equals",
                            "values": [
                              "credit_card"
                            ]
                          }
                        ],
                        "measures": [
                          "order_details.payments_total_amount"
                        ]
                      }
                    },
                    "refId": "Credit Card",
                    "hidden": true
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-cube-datasource",
                      "version": "v0",
                      "datasource": {
                        "name": "grafana-cube-datasource"
                      },
                      "spec": {
                        "dimensions": [
                          "order_details.customers_first_name"
                        ],
                        "filters": [
                          {
                            "member": "order_details.customers_is_active",
                            "operator": "equals",
                            "values": [
                              "true"
                            ]
                          }
                        ],
                        "measures": [
                          "order_details.payments_total_amount"
                        ]
                      }
                    },
                    "refId": "Active Customer",
                    "hidden": true
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "__expr__",
                      "version": "v0",
                      "datasource": {
                        "name": "__expr__"
                      },
                      "spec": {
                        "expression": "SELECT\n  ccac.`order_details.customers_first_name` AS first_name,\n  ccac.`order_details.payments_total_amount` AS total_amount_across_credit_card_OR_active_customer,\n  cc.`order_details.payments_total_amount` AS total_amount_across_credit_card,\n  ac.`order_details.payments_total_amount` AS total_amount_active_customer\nFROM\n  `Credit Card or Active Customer` AS ccac\nLEFT JOIN\n  `Credit Card` AS cc \n  ON ccac.`order_details.customers_first_name` = cc.`order_details.customers_first_name`\nLEFT JOIN\n  `Active Customer` AS ac \n  ON ccac.`order_details.customers_first_name` = ac.`order_details.customers_first_name`",
                        "type": "sql"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
