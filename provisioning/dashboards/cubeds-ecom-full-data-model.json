      "panel-9": {
        "kind": "Panel",
        "spec": {
          "id": 9,
          "title": "Advanced (JSON viewer demo): Orders for $customerName",
          "description": "This panel filters by a dashboard variable ($customerName) in a filter value. Change the Customer Name variable to see orders for a different customer. The query editor shows the JSON viewer because template variables in filter values are not supported by the visual builder.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-cube-datasource",
                      "version": "v0",
                      "datasource": {
                        "name": "grafana-cube-datasource"
                      },
                      "spec": {
                        "dimensions": [
                          "order_details.payments_payment_method",
                          "order_details.is_gift",
                          "order_details.payments_discount"
                        ],
                        "filters": [
                          {
                            "member": "order_details.customers_first_name",
